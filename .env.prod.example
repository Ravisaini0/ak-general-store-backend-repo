SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:mysql://your-db-host:3306/ak_general_store
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
JWT_SECRET=replace_with_a_very_long_random_secret_value
SMTP_USERNAME=your_verified_sender@example.com
SMTP_PASSWORD=your_app_or_provider_password
OTP_FROM_EMAIL=your_verified_sender@example.com
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://yourstore.com,https://www.yourstore.com,https://admin.yourstore.com
PAYMENT_RAZORPAY_ENABLED=true
PAYMENT_RAZORPAY_KEY_ID=your_razorpay_key
PAYMENT_RAZORPAY_KEY_SECRET=your_razorpay_secret
JAVA_HOME=C:\Program Files\Java\jdk-21
